rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.uid in [
        "telegram:17446512204177543088"
      ];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      allow create: if isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'balance',
          'cart',
          'scannedCodes',
          'transactions',
          'streakInfo',
          'firstName',
          'lastName',
          'username',
          'photoUrl',
          'authProvider',
          'telegramId',
          'createdAt',
          'lastLoginAt',
          'displayName',
          'phone',
          'addresses',
          'orders'
        ]);

      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'cart',
          'displayName',
          'phone',
          'addresses',
          'orders'
        ])
      );

      allow delete: if isAdmin();
    }

    match /market_items/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /food_items/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /food_services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /partners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promo_codes/{docId} {
      allow read, write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}